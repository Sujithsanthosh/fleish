# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=fleish_fresh

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Razorpay
RAZORPAY_KEY_ID=placeholder
RAZORPAY_KEY_SECRET=placeholder

# Firebase
FIREBASE_SENDER_ID=placeholder
FIREBASE_SERVER_KEY=placeholder

# Maps
GOOGLE_MAPS_API_KEY=placeholder

# Supabase Storage & Database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key
DB_SSL=true # required for Supabase outside of local environments
